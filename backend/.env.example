# YouTube Bulk Editor — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub — it contains your client secret
#
# Copyright (c) 2025 Chirag Mehta
# github.com/imchikachirag/youtube-bulk-editor

# From Google Cloud Console > APIs & Services > Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# The URL Google redirects to after login
# Must match exactly what you set in Google Cloud Console
# Local dev:  http://localhost:8080/auth/callback
# Production: https://YOUR-CLOUD-RUN-URL/auth/callback
REDIRECT_URI=http://localhost:8080/auth/callback

# Where to send the user after login (your frontend URL)
# Local dev:  http://localhost:3000
# Production: https://chiragmehta.info/youtube-bulk-editor
FRONTEND_URL=http://localhost:3000

# Port (Cloud Run sets this automatically, leave as 8080 locally)
PORT=8080
